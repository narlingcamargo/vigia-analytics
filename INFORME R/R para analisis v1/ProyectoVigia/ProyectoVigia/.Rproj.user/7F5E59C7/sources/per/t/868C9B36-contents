```{r casosxdepartamento}

library(readxl) 
library(dplyr) 
library(ggplot2) 
library(sf) 
library(geodata)

library(stringi) # Para quitar tildes fácilmente


# 1. Estandarizar tus datos
casos_departamento <- resultados %>% 
  group_by(DEPARTAMENTO) %>% 
  summarise(total_casos = n()) %>%
  mutate(DEPARTAMENTO = toupper(stri_trans_general(DEPARTAMENTO, "Latin-ASCII")))

# 2. Ajustar nombres específicos de tu base si es necesario
casos_departamento$DEPARTAMENTO <- recode(
  casos_departamento$DEPARTAMENTO,
  "BOGOTA D.C." = "SANTAFE DE BOGOTA", # GADM suele usar este o "Bogota"
  "VALLE" = "VALLE DEL CAUCA",
  "SAN ANDRES Y PROVIDENCIA" = "ARCHIPIELAGO DE SAN ANDRES, PROVIDENCIA Y SANTA CATALINA"
)

# 3. Estandarizar el mapa de GADM
colombia_sf <- st_as_sf(geodata::gadm(country = "COL", level = 1, path = tempdir())) %>%
  mutate(NAME_1_CLEAN = toupper(stri_trans_general(NAME_1, "Latin-ASCII")))

# 4. Unir
mapa_casos <- colombia_sf %>% 
  left_join(casos_departamento, by = c("NAME_1_CLEAN" = "DEPARTAMENTO"))

# 5. Graficar
ggplot(mapa_casos) +
  geom_sf(aes(fill = total_casos), color = "white", size = 0.2) +
  scale_fill_viridis_c(
    option = "plasma",
    na.value = "#eeeeee",
    name = "Total Casos",
    labels = scales::comma # Para que los números grandes se vean bien
  ) +
  theme_void() + # Quita las coordenadas (lat/long) para un look más limpio
  labs(
    title = "Distribución de casos por departamento en Colombia",
    subtitle = "Fuente: Base BD_FINAL"
  )

```

